doctype html
html(lang='en')

    head

        meta(charset='utf-8')
        meta(name='viewport', content='width=device-width, initial-scale=1, shrink-to-fit=no')
        meta(name='description', content='')
        meta(name='author', content='')

        title Eric's Blog

        link(rel='icon', type='image/x-icon', href='assets/logo.png')

        // Font Awesome icons (free version)
        script(src='https://use.fontawesome.com/releases/v5.15.3/js/all.js', crossorigin='anonymous')

        // Google fonts
        link(href='https://fonts.googleapis.com/css?family=Lora:400,700,400italic,700italic', rel='stylesheet', type='text/css')
        link(href='https://fonts.googleapis.com/css?family=Open+Sans:300italic,400italic,600italic,700italic,800italic,400,300,600,700,800', rel='stylesheet', type='text/css')

        // Core theme CSS (includes Bootstrap)
        link(href='css/styles.css', rel='stylesheet')

    body

        // Navigation
        nav#mainNav.navbar.navbar-expand-lg.navbar-light.fixed-top
            .container
                img(src="assets/logo.png" width="50" height="50")
                a.navbar-brand(href='index.html') Eric Wu 
                button.navbar-toggler.navbar-toggler-right(type='button', data-toggle='collapse', data-target='#navbarResponsive', aria-controls='navbarResponsive', aria-expanded='false', aria-label='Toggle navigation')
                    | Menu
                    i.fas.fa-bars
                #navbarResponsive.collapse.navbar-collapse
                    ul.navbar-nav.ml-auto
                        li.nav-item
                            a.nav-link(href='index.html') Home
                        li.nav-item
                            a.nav-link(href='about.html') About
                        li.nav-item
                            a.nav-link(href='project.html') Project
                        li.nav-item
                            a.nav-link(href='contact.html') Contact

        // Page Header
        header.masthead(style="background-image: url('assets/img/home-bg.jpg')")
            .overlay
            .container
                .row
                    .col-lg-8.col-md-10.mx-auto
                        .site-heading
                            h1 Eric's Blog
                            span.subheading "Live as if you were to die tomorrow. Learn as if you were to live forver." - Mahatma Gandhi
        // Main Content
        .container
            .row
                .col-lg-8.col-md-10.mx-auto
                    .post-preview
                        a(href='/post/2021-05-23-simple-file-uploading-web-app-part-1.html')
                            h2.post-title
                                | Simple file uploading web app
                            h3.post-subtitle
                                | Implement a web app that uploads and display images from Google drive (App Script + Drive API)
                        p.post-meta
                            | Posted by
                            a(href='index.html') Eric Wu
                            | on May 23, 2021
                    hr
                    .post-preview
                        a(href='/post/2021-04-12-gis-record-searching-system-in-c-plus-plus.html')
                            h2.post-title
                                | GIS record searching system in C++
                            h3.post-subtitle
                                | Implment a GIS record searching system with Hashtable + PR quadtree + bufferpool
                        p.post-meta
                            | Posted by
                            a(href='index.html') Eric Wu
                            | on April 12, 2021
                    hr
                    .post-preview
                        a(href='/post/2021-04-11-sudoku-solver-in-c-plus-plus.html')
                            h2.post-title
                                | Sudoku Solver in C++
                            h3.post-subtitle
                                | Implement a Sudoku solver with alogrithm X + dancing links (brute force)
                        p.post-meta
                            | Posted by
                            a(href='index.html') Eric Wu
                            | on April 11, 2021
                    hr
                    .post-preview
                        a(href='/post/2021-04-03-exploiting-bluetooth-ctkd-vulnerability.html')
                            h2.post-title
                                | Exploiting Bluetooth CTKD vulnerability
                            h3.post-subtitle
                                | The discovered Bluetooth vulnerability (CVE-2020-15802) makes it possible for attacker to steal Bluetooth session
                        p.post-meta
                            | Posted by
                            a(href='index.html') Eric Wu
                            | on April 03, 2021
                    hr

                    // Pager
                    .clearfix
                        a.btn.btn-primary.float-right(href='project.html') See More →
        hr
        // Footer
        footer
            .container
                .row
                    .col-lg-8.col-md-10.mx-auto
                        ul.list-inline.text-center
                            li.list-inline-item
                                a(href='https://linkedin.com/in/ericwu1997')
                                    span.fa-stack.fa-lg
                                        i.fas.fa-circle.fa-stack-2x
                                        i.fab.fa-linkedin.fa-stack-1x.fa-inverse
                            li.list-inline-item
                                a(href='https://github.com/ericwu1997')
                                    span.fa-stack.fa-lg
                                        i.fas.fa-circle.fa-stack-2x
                                        i.fab.fa-github.fa-stack-1x.fa-inverse
                        p.copyright.text-muted Copyright &copy; Your Website 2021

        // Bootstrap core JS
        script(src='https://code.jquery.com/jquery-3.5.1.min.js')
        script(src='https://cdn.jsdelivr.net/npm/bootstrap@4.6.0/dist/js/bootstrap.bundle.min.js')

        // Core theme JS
        script(src='js/scripts.js')
